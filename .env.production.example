NODE_ENV=production

# Database — Railway: MySQL service > Connect tab
DB_HOST=your-mysql-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CHANGE_ME
DB_NAME=railway
# DB_CONNECTION_LIMIT=2  (serverless default — leave unset)

# Auth
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=24h

# Stripe (live keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# URLs — set to your Vercel domain
APP_URL=https://your-app.vercel.app
LANDING_URL=https://your-landing.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-landing.vercel.app

# Registration
REGISTRATION_MODE=stripe_only
ADMIN_REGISTRATION_KEY=CHANGE_ME_LONG_RANDOM

# Logging
LOG_LEVEL=info
